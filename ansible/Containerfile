FROM quay.io/fedora/fedora-minimal@sha256:8e80d06df5060f39796fbe84d2aa4b75ead1ccd759d86228e3498505da4f7aa1

RUN dnf install -y \
  ansible \
  && dnf clean all

RUN mkdir /ansible

COPY ./*.yml /ansible/
COPY ./inventory /ansible/inventory
COPY ./roles /ansible/roles
COPY ./ansible.cfg /ansible/ansible.cfg

ENTRYPOINT [ "/usr/bin/ansible-playbook" ]
