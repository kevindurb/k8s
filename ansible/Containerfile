FROM quay.io/fedora/fedora-minimal@sha256:9b2cb358c580e1c883eb46f6687f5487c62c3d6a23558aa61219b31954db8ccd

RUN dnf install -y \
  ansible \
  && dnf clean all

RUN mkdir /ansible

COPY ./*.yml /ansible/
COPY ./inventory /ansible/inventory
COPY ./roles /ansible/roles
COPY ./ansible.cfg /ansible/ansible.cfg

ENTRYPOINT [ "/usr/bin/ansible-playbook" ]
