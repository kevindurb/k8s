{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":automergeDigest",
    ":automergeLinters",
    ":automergePatch",
    ":automergeMinor",
    ":disableRateLimiting"
  ],
  "ignoreTests": true,
  "automergeType": "pr",
  "automergeStrategy": "merge-commit",
  "platform": "github",
  "repositories": ["kevindurb/k8s"],
  "kubernetes": {
    "managerFilePatterns": ["/apps/.+\\.yaml$/", "/apps/.+\\.yml$/"]
  },
  "argocd": {
    "managerFilePatterns": ["/apps/.+app\\.yml$/", "/apps/.+app\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/ublue-os/ucore", "quay.io/fedora/fedora-minimal"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update _VERSION variables in Dockerfiles",
      "managerFilePatterns": ["/(^|/|\\.)Containerfile$/", "/(^|/)Containerfile\\.[^/]*$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s(?:ENV|ARG) .+?_VERSION=(?<currentValue>.+?)\\s"
      ]
    }
  ]
}
